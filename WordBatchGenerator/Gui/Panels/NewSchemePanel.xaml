<Page x:Class="WordBatchGenerator.Gui.Panels.NewSchemePanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      mc:Ignorable="d"
      d:DesignHeight="680" d:DesignWidth="860"
      Background="Transparent">

    <Grid Margin="20" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform Y="25"/>
        </Grid.RenderTransform>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         To="1"
                                         Duration="0:0:0.35">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                         To="0"
                                         Duration="0:0:0.45">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>
        <Grid.RowDefinitions>
            <!-- 顶部标题与配置区 -->
            <RowDefinition Height="Auto"/>
            <!-- 下部主要内容区 -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 1. 顶部标题与配置区 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题和副标题 -->
            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="创建与编辑方案"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#1F2421"
                           Margin="0,0,0,2"/>
                <TextBlock Text="在下方的 Word 预览中划选文字，在右侧输入框中直接标注为变量"
                           FontSize="12.5"
                           Foreground="#5C635D"/>
            </StackPanel>

            <!-- 方案基本配置 (紧凑型横向卡片) -->
            <Border Grid.Row="1"
                    Background="White"
                    BorderBrush="#E7E1D7"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16,10"
                    Margin="0,0,0,4">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12"
                                      ShadowDepth="3"
                                      Opacity="0.04"
                                      Color="#000000"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <!-- 方案名称 -->
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="220"/>
                        <!-- 间距 -->
                        <ColumnDefinition Width="32"/>
                        <!-- Word 模板文件 -->
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 方案名称 Label & TextBox -->
                    <TextBlock Grid.Column="0"
                               Text="方案名称"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#1F2421"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <TextBox x:Name="TxtSchemeName"
                             Grid.Column="1"
                             Height="34"
                             FontSize="13"
                             Background="White"
                             BorderBrush="#E7E1D7"
                             BorderThickness="1.5"
                             VerticalContentAlignment="Center"
                             TextWrapping="NoWrap"
                             AcceptsReturn="False"
                             Padding="8,0"
                             VerticalAlignment="Center"
                             Tag="请输入方案名称，例如：合同方案..."/>

                    <!-- Word 模板文件 Label & TextBox + Button -->
                    <TextBlock Grid.Column="3"
                               Text="Word 模板"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#1F2421"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <Grid Grid.Column="4" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtTemplatePath"
                                 Grid.Column="0"
                                 Height="34"
                                 FontSize="13"
                                 IsReadOnly="True"
                                 Background="#F7F4EF"
                                 BorderBrush="#E7E1D7"
                                 BorderThickness="1.5"
                                 VerticalContentAlignment="Center"
                                 Padding="8,0"
                                 Margin="0,0,8,0"
                                 Tag="请选择或拖入 Word 模板文件路径 (.docx)..."/>
                        <Button Grid.Column="1"
                                x:Name="BtnBrowseTemplate"
                                Content="导入模板"
                                Style="{StaticResource PrimaryButton}"
                                Width="85"
                                Height="34"
                                FontSize="13"
                                Click="BtnBrowseTemplate_Click"
                                Padding="0"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- 2. 下部主要内容区 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- 左侧 Word 预览 -->
                <ColumnDefinition Width="*"/>
                <!-- 右侧变量标注与管理 -->
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：Word 预览区 -->
            <Grid Grid.Column="0" Margin="0,0,20,0">
                <Border x:Name="WordPreviewBorder"
                        Background="White"
                        BorderBrush="#E7E1D7"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="4">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12"
                                          ShadowDepth="3"
                                          Opacity="0.06"
                                          Color="#000000"/>
                    </Border.Effect>
                    <wv2:WebView2 x:Name="WordPreview"/>
                </Border>

                <!-- Fallback UI when WebView2 is missing -->
                <Border x:Name="PanelWebViewError"
                        Background="#F7F4EF"
                        BorderBrush="#E7E1D7"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="20"
                        Visibility="Collapsed">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12"
                                          ShadowDepth="3"
                                          Opacity="0.06"
                                          Color="#000000"/>
                    </Border.Effect>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="480">
                        <TextBlock Text="💡" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="未检测到 WebView2 运行环境"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#C4612F"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>
                        <TextBlock Text="此功能需要 Microsoft Edge WebView2 运行环境来预览 Word 文档并标注变量。当前系统缺失该组件（常见于精简版 Windows 系统或长期关闭更新的 Win10 系统）。"
                                   FontSize="13.5"
                                   Foreground="#5C635D"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   LineHeight="1.6"
                                   Margin="0,0,0,24"/>
                        <Button Content="📥 前往下载 WebView2 运行时"
                                Height="38"
                                Width="260"
                                Padding="0"
                                Style="{StaticResource PrimaryButton}"
                                Click="BtnDownloadWebView2_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 右侧：控制面板 -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <!-- 变量快速标注 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 已标注变量列表 -->
                    <RowDefinition Height="*"/>
                    <!-- 底部状态栏与保存 -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 2.1. 变量快速标注 -->
                <Border Grid.Row="0"
                        Background="White"
                        BorderBrush="#E7E1D7"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="16"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="变量快速标注"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2421"
                                   Margin="0,0,0,8"/>

                        <!-- Selection Feedback Card -->
                        <Border x:Name="SelectionCard"
                                Background="#FFFBF8"
                                BorderBrush="#F3EBE5"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,10"
                                Margin="0,0,0,12"
                                MinHeight="56">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="💡" 
                                           FontSize="15" 
                                           VerticalAlignment="Center" 
                                           Margin="0,0,8,0"/>
                                <TextBlock x:Name="TxtSelectionText"
                                           Grid.Column="1"
                                           Text="请在左侧预览区中划选变量文本"
                                           FontSize="12"
                                           FontWeight="Medium"
                                           Foreground="#8A8070"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="TxtVariableName"
                                      Grid.Column="0"
                                      Height="34"
                                      FontSize="13"
                                      Background="White"
                                      BorderBrush="#C4612F"
                                      BorderThickness="1.5"
                                      VerticalContentAlignment="Center"
                                      Margin="0,0,8,0"
                                      IsEditable="True"/>
                            <Button Grid.Column="1"
                                    x:Name="BtnAddVariable"
                                    Content="标注"
                                    IsEnabled="False"
                                    Width="60"
                                    Height="34"
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Background="{StaticResource SageGreenBrush}"
                                    Cursor="Hand"
                                    Click="BtnAddVariable_Click"
                                    RenderTransformOrigin="0.5,0.5">
                                <Button.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Button.RenderTransform>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid>
                                            <Border x:Name="BaseBorder" Background="{TemplateBinding Background}" CornerRadius="8"/>
                                            <Border x:Name="HoverBorder" Background="{StaticResource SageGreenHoverBrush}" CornerRadius="8" Opacity="0"/>
                                            <Border x:Name="PressedBorder" Background="#385846" CornerRadius="8" Opacity="0"/>
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="HoverBorder"
                                                                             Storyboard.TargetProperty="Opacity"
                                                                             To="1" Duration="0:0:0.15"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                             To="1.03" Duration="0:0:0.15"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                             To="1.03" Duration="0:0:0.15"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="HoverBorder"
                                                                             Storyboard.TargetProperty="Opacity"
                                                                             To="0" Duration="0:0:0.15"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                             To="1" Duration="0:0:0.15"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                             To="1" Duration="0:0:0.15"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                             To="0.96" Duration="0:0:0.08"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                             To="0.96" Duration="0:0:0.08"/>
                                                            <DoubleAnimation Storyboard.TargetName="PressedBorder"
                                                                             Storyboard.TargetProperty="Opacity"
                                                                             To="1" Duration="0:0:0.08"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                             To="1.03" Duration="0:0:0.08"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                             To="1.03" Duration="0:0:0.08"/>
                                                            <DoubleAnimation Storyboard.TargetName="PressedBorder"
                                                                             Storyboard.TargetProperty="Opacity"
                                                                             To="0" Duration="0:0:0.08"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 2.2. 已标注变量列表 -->
                <Border Grid.Row="1"
                        Background="White"
                        BorderBrush="#E7E1D7"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="16"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="已标注变量列表"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2421"
                                   Margin="0,0,0,8"/>

                        <ListBox x:Name="LstVariables"
                                 Grid.Row="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0"
                                 FontSize="13"
                                 SelectionMode="Single"
                                 HorizontalContentAlignment="Stretch"
                                 PreviewMouseLeftButtonUp="LstVariables_PreviewMouseLeftButtonUp"
                                 KeyUp="LstVariables_KeyUp">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid HorizontalAlignment="Stretch" Height="28">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="🏷️" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding}" VerticalAlignment="Center" Foreground="#1F2421"/>
                                        <Button Grid.Column="2" 
                                                Content="✕" 
                                                Width="20" Height="20"
                                                FontSize="9"
                                                FontWeight="Bold"
                                                Foreground="#9CA39E"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                ToolTip="移除此变量"
                                                Click="BtnDeleteVariableItem_Click"
                                                Tag="{Binding}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="8,4"/>
                                    <Setter Property="Margin" Value="0,0,0,4"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Name="ItemBorder"
                                                        Background="{TemplateBinding Background}"
                                                        BorderThickness="0"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Stretch"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="#FFFBF8"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="#F2E3D6"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- 2.3. 状态栏与保存按钮 -->
                <StackPanel Grid.Row="2">
                    <!-- 状态反馈 -->
                    <Border Background="#E8F5E9"
                            BorderBrush="#A5D6A7"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,0,12"
                            x:Name="StatusBar"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="TxtStatus"
                                       Grid.Column="0"
                                       Text="✅ 模板加载成功"
                                       FontSize="12"
                                       Foreground="#2E7D32"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtVariableCount"
                                       Grid.Column="1"
                                       Text="0 个变量"
                                       FontSize="11"
                                       Foreground="#5C635D"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- 保存按钮 -->
                    <Button x:Name="BtnSave"
                            Content="保存方案"
                            Style="{StaticResource PrimaryButton}"
                            Height="44"
                            FontSize="14"
                            Click="BtnSave_Click"
                            Padding="0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
