<Page x:Class="WordBatchGenerator.Gui.Panels.NewSchemePanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      mc:Ignorable="d"
      d:DesignHeight="680" d:DesignWidth="860"
      Background="Transparent">

    <Grid Margin="20" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform Y="25"/>
        </Grid.RenderTransform>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         To="1"
                                         Duration="0:0:0.35">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                         To="0"
                                         Duration="0:0:0.45">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>
        <Grid.RowDefinitions>
            <!-- 顶部标题与配置区 -->
            <RowDefinition Height="Auto"/>
            <!-- 下部主要内容区 -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 1. 顶部标题与配置区 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题和副标题 -->
            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="创建与编辑方案"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#1F2421"
                           Margin="0,0,0,2"/>
                <TextBlock Text="在下方的 Word 预览中划选文字，在右侧输入框中直接标注为变量"
                           FontSize="12.5"
                           Foreground="#5C635D"/>
            </StackPanel>

            <!-- 方案基本配置 (紧凑型横向卡片) -->
            <Border Grid.Row="1"
                    Background="White"
                    BorderBrush="#E7E1D7"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16,10"
                    Margin="0,0,0,4">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12"
                                      ShadowDepth="3"
                                      Opacity="0.04"
                                      Color="#000000"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <!-- 方案名称 -->
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="220"/>
                        <!-- 间距 -->
                        <ColumnDefinition Width="32"/>
                        <!-- Word 模板文件 -->
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 方案名称 Label & TextBox -->
                    <TextBlock Grid.Column="0"
                               Text="方案名称"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#1F2421"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <TextBox x:Name="TxtSchemeName"
                             Grid.Column="1"
                             Height="34"
                             FontSize="13"
                             Background="White"
                             BorderBrush="#E7E1D7"
                             BorderThickness="1.5"
                             VerticalContentAlignment="Center"
                             TextWrapping="NoWrap"
                             AcceptsReturn="False"
                             Padding="8,0"
                             VerticalAlignment="Center"
                             Tag="请输入方案名称，例如：合同方案..."/>

                    <!-- Word 模板文件 Label & TextBox + Button -->
                    <TextBlock Grid.Column="3"
                               Text="Word 模板"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#1F2421"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <Grid Grid.Column="4" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtTemplatePath"
                                 Grid.Column="0"
                                 Height="34"
                                 FontSize="13"
                                 IsReadOnly="True"
                                 Background="#F7F4EF"
                                 BorderBrush="#E7E1D7"
                                 BorderThickness="1.5"
                                 VerticalContentAlignment="Center"
                                 Padding="8,0"
                                 Margin="0,0,8,0"
                                 Tag="请选择或拖入 Word 模板文件路径 (.docx)..."/>
                        <Button Grid.Column="1"
                                x:Name="BtnBrowseTemplate"
                                Content="导入模板"
                                Style="{StaticResource PrimaryButton}"
                                Width="85"
                                Height="34"
                                FontSize="13"
                                Click="BtnBrowseTemplate_Click"
                                Padding="0"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- 2. 下部主要内容区 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- 左侧 Word 预览 -->
                <ColumnDefinition Width="*"/>
                <!-- 右侧变量标注与管理 -->
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：Word 预览区 -->
            <Grid Grid.Column="0" Margin="0,0,20,0">
                <Border Background="White"
                        BorderBrush="#E7E1D7"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="4">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12"
                                          ShadowDepth="3"
                                          Opacity="0.06"
                                          Color="#000000"/>
                    </Border.Effect>
                    <wv2:WebView2 x:Name="WordPreview"/>
                </Border>
            </Grid>

            <!-- 右侧：控制面板 -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <!-- 变量快速标注 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 已标注变量列表 -->
                    <RowDefinition Height="*"/>
                    <!-- 底部状态栏与保存 -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 2.1. 变量快速标注 -->
                <Border Grid.Row="0"
                        Background="White"
                        BorderBrush="#E7E1D7"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="16"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="变量快速标注"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2421"
                                   Margin="0,0,0,8"/>

                        <TextBlock x:Name="TxtSelectionText"
                                   Text="当前选中: 未选择文本"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#C4612F"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8"
                                   MinHeight="36"/>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="TxtVariableName"
                                      Grid.Column="0"
                                      Height="34"
                                      FontSize="13"
                                      Background="White"
                                      BorderBrush="#C4612F"
                                      BorderThickness="1.5"
                                      VerticalContentAlignment="Center"
                                      Margin="0,0,8,0"
                                      IsEditable="True"/>
                            <Button Grid.Column="1"
                                    x:Name="BtnAddVariable"
                                    Content="标注"
                                    Width="60"
                                    Height="34"
                                    FontSize="13"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Background="#4CAF50"
                                    Cursor="Hand"
                                    Click="BtnAddVariable_Click"
                                    RenderTransformOrigin="0.5,0.5">
                                <Button.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Button.RenderTransform>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <ColorAnimation Storyboard.TargetName="BtnBorder"
                                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                            To="#45A049" Duration="0:0:0.15"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                             To="1.03" Duration="0:0:0.15"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                             To="1.03" Duration="0:0:0.15"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <ColorAnimation Storyboard.TargetName="BtnBorder"
                                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                            To="#4CAF50" Duration="0:0:0.15"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                             To="1" Duration="0:0:0.15"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                             To="1" Duration="0:0:0.15"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                             To="0.96" Duration="0:0:0.08"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                             To="0.96" Duration="0:0:0.08"/>
                                                            <ColorAnimation Storyboard.TargetName="BtnBorder"
                                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                            To="#388E3C" Duration="0:0:0.08"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                             To="1.03" Duration="0:0:0.08"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                             To="1.03" Duration="0:0:0.08"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 2.2. 已标注变量列表 -->
                <Border Grid.Row="1"
                        Background="White"
                        BorderBrush="#E7E1D7"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="16"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="已标注变量列表"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2421"
                                   Margin="0,0,0,8"/>

                        <ListBox x:Name="LstVariables"
                                 Grid.Row="1"
                                 Background="#F7F4EF"
                                 BorderBrush="#E7E1D7"
                                 BorderThickness="1"
                                 Padding="4"
                                 FontSize="13"
                                 SelectionMode="Single"
                                 PreviewMouseLeftButtonUp="LstVariables_PreviewMouseLeftButtonUp"
                                 KeyUp="LstVariables_KeyUp">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="10,8"/>
                                    <Setter Property="Margin" Value="0,0,0,3"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Name="ItemBorder"
                                                        Background="{TemplateBinding Background}"
                                                        BorderThickness="0"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="#FFF7F0"/>
                                                        <Setter Property="Foreground" Value="#C4612F"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="#F2E3D6"/>
                                                        <Setter Property="Foreground" Value="#C4612F"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <Button Grid.Row="2"
                                Content="移除选中变量"
                                Style="{StaticResource DangerButton}"
                                Height="34"
                                FontSize="13"
                                Click="BtnRemoveVariable_Click"
                                Margin="0,8,0,0"
                                Padding="0"/>
                    </Grid>
                </Border>

                <!-- 2.3. 状态栏与保存按钮 -->
                <StackPanel Grid.Row="2">
                    <!-- 状态反馈 -->
                    <Border Background="#E8F5E9"
                            BorderBrush="#A5D6A7"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,0,0,12"
                            x:Name="StatusBar"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="TxtStatus"
                                       Grid.Column="0"
                                       Text="✅ 模板加载成功"
                                       FontSize="12"
                                       Foreground="#2E7D32"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtVariableCount"
                                       Grid.Column="1"
                                       Text="0 个变量"
                                       FontSize="11"
                                       Foreground="#5C635D"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- 保存按钮 -->
                    <Button x:Name="BtnSave"
                            Content="保存方案"
                            Style="{StaticResource PrimaryButton}"
                            Height="44"
                            FontSize="14"
                            Click="BtnSave_Click"
                            Padding="0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
