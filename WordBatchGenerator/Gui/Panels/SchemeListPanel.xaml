<Page x:Class="WordBatchGenerator.Gui.Panels.SchemeListPanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="680" d:DesignWidth="860"
      Background="Transparent">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题行 -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="方案管理"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#1F2421"
                           Margin="0,0,0,4"/>
                <TextBlock Text="已保存的所有生成方案"
                           FontSize="14"
                           Foreground="#5C635D"/>
            </StackPanel>

            <!-- 导入按钮 -->
            <Button Grid.Column="1"
                    x:Name="BtnImport"
                    Content="📦 导入方案"
                    Width="130"
                    Height="44"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Background="#C4612F"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    HorizontalAlignment="Right"
                    Click="BtnImportScheme_Click"/>
        </Grid>

        <!-- 空状态提示 -->
        <TextBlock x:Name="TxtEmpty"
                   Grid.Row="2"
                   Text="暂无方案，请先创建新方案"
                   FontSize="16"
                   Foreground="#9CA39E"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="0,60,0,0"
                   Visibility="Collapsed"/>

        <!-- 方案卡片列表 -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="SchemeItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White"
                                BorderBrush="#E7E1D7"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="24"
                                Margin="0,0,0,16">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12"
                                                  ShadowDepth="3"
                                                  Opacity="0.08"
                                                  Color="#000000"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 方案信息 -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="#1F2421"
                                               Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock FontSize="13" Foreground="#5C635D">
                                            <Run Text="变量: " FontWeight="SemiBold"/>
                                            <Run Text="{Binding Variables.Count, Mode=OneWay}"/>
                                            <Run Text=" 个"/>
                                        </TextBlock>
                                        <TextBlock FontSize="13" Foreground="#9CA39E" Margin="16,0,0,0">
                                            <Run Text="创建: "/>
                                            <Run Text="{Binding CreatedAt, StringFormat='yyyy-MM-dd HH:mm', Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>

                                <!-- 操作按钮 -->
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button Content="使用"
                                            Width="85"
                                            Height="40"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Background="#2196F3"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Margin="0,0,10,0"
                                            Cursor="Hand"
                                            Click="BtnUseScheme_Click"
                                            Tag="{Binding Name}"/>
                                    <Button Content="编辑"
                                            Width="85"
                                            Height="40"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Background="#4CAF50"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Margin="0,0,10,0"
                                            Cursor="Hand"
                                            Click="BtnEditScheme_Click"
                                            Tag="{Binding Name}"/>
                                    <Button Content="导出"
                                            Width="85"
                                            Height="40"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Background="#FF9800"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Margin="0,0,10,0"
                                            Cursor="Hand"
                                            Click="BtnExportScheme_Click"
                                            Tag="{Binding Name}"/>
                                    <Button Content="删除"
                                            Width="85"
                                            Height="40"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Background="#F44336"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Click="BtnDeleteScheme_Click"
                                            Tag="{Binding Name}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
