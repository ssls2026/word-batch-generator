<Page x:Class="WordBatchGenerator.Gui.Panels.GeneratePanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="680" d:DesignWidth="860"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" Opacity="0">
            <StackPanel.RenderTransform>
                <TranslateTransform Y="25"/>
            </StackPanel.RenderTransform>
            <StackPanel.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             To="1"
                                             Duration="0:0:0.35">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                             To="0"
                                             Duration="0:0:0.45">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </StackPanel.Triggers>
            <!-- 页面标题 -->
            <TextBlock Text="批量生成文件"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#1F2421"
                       Margin="0,0,0,8"/>
            <TextBlock Text="选择方案 → 导入数据 → 一键生成"
                       FontSize="14"
                       Foreground="#5C635D"
                       Margin="0,0,0,24"/>

            <!-- ===== 选择方案 ===== -->
            <Border Background="White"
                    BorderBrush="#E7E1D7"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="选择方案"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#1F2421"
                               Margin="0,0,0,8"/>
                    <ComboBox x:Name="CmbSchemes"
                              Height="44"
                              FontSize="14"
                              Padding="10,0"
                              Background="White"
                              BorderBrush="#E7E1D7"
                              BorderThickness="1.5"
                              VerticalContentAlignment="Center"
                              IsEditable="False"
                              SelectionChanged="CmbSchemes_SelectionChanged"/>
                </StackPanel>
            </Border>

            <!-- ===== 数据输入源双页签 ===== -->
            <Border Background="White"
                    BorderBrush="#E7E1D7"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TabControl x:Name="DataInputTabs" 
                                BorderThickness="0,1,0,0" 
                                BorderBrush="#EBE7DE"
                                Background="Transparent"
                                SelectionChanged="DataInputTabs_SelectionChanged">
                        <!-- 页签 1: 📊 导入 Excel 数据 -->
                        <TabItem Header="📊 导入 Excel 数据" Padding="12,6">
                            <StackPanel Margin="0,16,0,0">
                                <TextBlock Text="Excel 数据源"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#1F2421"
                                           Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox x:Name="TxtExcelPath"
                                             Grid.Column="0"
                                             Height="44"
                                             FontSize="14"
                                             IsReadOnly="True"
                                             Background="#F7F4EF"
                                             BorderBrush="#E7E1D7"
                                             BorderThickness="1.5"
                                             VerticalContentAlignment="Center"
                                             Margin="0,0,12,0"
                                             Tag="请选择或拖入 Excel 数据源文件路径..."/>

                                    <Button Grid.Column="1"
                                            x:Name="BtnBrowseExcel"
                                            Content="导入 Excel"
                                            Width="110"
                                            Height="44"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Background="#C4612F"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Click="BtnBrowseExcel_Click"
                                            Cursor="Hand"
                                            Margin="0,0,10,0"/>

                                    <Button Grid.Column="2"
                                            x:Name="BtnOpenExcel"
                                            Content="打开 Excel"
                                            Width="110"
                                            Height="44"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="BtnOpenExcel_Click"
                                            Cursor="Hand"
                                            Margin="0,0,10,0"
                                            IsEnabled="False"/>

                                    <Button Grid.Column="3"
                                            x:Name="BtnExportExcelTemplate"
                                            Content="下载模板"
                                            Width="110"
                                            Height="44"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Background="White"
                                            Foreground="#C4612F"
                                            BorderBrush="#C4612F"
                                            BorderThickness="1.5"
                                            Click="BtnExportExcelTemplate_Click"
                                            Cursor="Hand"/>
                                </Grid>
                            </StackPanel>
                        </TabItem>

                        <!-- 页签 2: ✍️ 手动粘贴文本 -->
                        <TabItem Header="✍️ 手动粘贴文本" Padding="12,6">
                            <StackPanel Margin="0,16,0,0">
                                <TextBlock Text="✍️ 变量数据粘贴"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#1F2421"
                                           Margin="0,0,0,8"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300" Margin="0,4,0,0">
                                    <UniformGrid x:Name="PasteInputsGrid" Columns="2" HorizontalAlignment="Stretch"/>
                                </ScrollViewer>
                            </StackPanel>
                        </TabItem>
                    </TabControl>

                    <!-- 公共数据预览表格 (在双页签下方) -->
                    <Border Background="White"
                            BorderBrush="#E7E1D7"
                            BorderThickness="1"
                            CornerRadius="12"
                            Margin="0,16,0,0"
                            x:Name="DataPreviewBorder"
                            Visibility="Collapsed">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12"
                                              ShadowDepth="3"
                                              Opacity="0.04"
                                              Color="#000000"/>
                        </Border.Effect>
                        <StackPanel>
                            <Grid Margin="16,12,16,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Grid.Column="0">
                                    <TextBlock Text="📊" FontSize="15" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="数据预览" 
                                               FontSize="13" 
                                               FontWeight="Bold" 
                                               Foreground="#C4612F"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtDataPreviewSubtitle"
                                               Text="(共 0 行)" 
                                               FontSize="11.5" 
                                               Foreground="#9CA39E"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"/>
                                </StackPanel>
                            </Grid>
                            
                            <Border BorderBrush="#EBE7DE" BorderThickness="0,0,0,1" Margin="0,0,0,4"/>
                            
                            <Border BorderBrush="#EBE7DE"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Background="White"
                                    Margin="16,4,16,16">
                                <DataGrid x:Name="DataPreviewGrid"
                                           AutoGenerateColumns="False"
                                           IsReadOnly="True"
                                           HeadersVisibility="Column"
                                           GridLinesVisibility="Horizontal"
                                           BorderThickness="0"
                                           Background="Transparent"
                                           RowBackground="White"
                                           AlternatingRowBackground="#FDFCFB"
                                           MaxHeight="240"
                                           CanUserAddRows="False"
                                           CanUserDeleteRows="False"
                                           HorizontalGridLinesBrush="#EBE7DE"
                                           RowHeight="36"
                                           FontSize="13">
                                     <DataGrid.Resources>
                                         <!-- 表头样式 -->
                                         <Style TargetType="DataGridColumnHeader">
                                             <Setter Property="Background" Value="#F5F1EB"/>
                                             <Setter Property="Foreground" Value="#1F2421"/>
                                             <Setter Property="FontWeight" Value="SemiBold"/>
                                             <Setter Property="Padding" Value="12,10"/>
                                             <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                             <Setter Property="BorderBrush" Value="#E8E2D9"/>
                                             <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                             <Setter Property="VerticalContentAlignment" Value="Center"/>
                                         </Style>
                                         <!-- 单元格样式 -->
                                         <Style TargetType="DataGridCell">
                                             <Setter Property="Padding" Value="12,6"/>
                                             <Setter Property="Template">
                                                 <Setter.Value>
                                                     <ControlTemplate TargetType="DataGridCell">
                                                         <Border Padding="{TemplateBinding Padding}" 
                                                                 Background="{TemplateBinding Background}" 
                                                                 BorderThickness="0" 
                                                                 SnapsToDevicePixels="True">
                                                             <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                                         </Border>
                                                     </ControlTemplate>
                                                 </Setter.Value>
                                             </Setter>
                                             <Style.Triggers>
                                                 <Trigger Property="IsSelected" Value="True">
                                                     <Setter Property="Background" Value="#F6EFE9"/>
                                                     <Setter Property="Foreground" Value="#C4612F"/>
                                                 </Trigger>
                                             </Style.Triggers>
                                         </Style>
                                     </DataGrid.Resources>
                                 </DataGrid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ===== 输出配置 ===== -->
            <Border Background="White"
                    BorderBrush="#E7E1D7"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12"
                                      ShadowDepth="3"
                                      Opacity="0.06"
                                      Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="输出配置"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#1F2421"
                               Margin="0,0,0,16"/>

                    <!-- 输出目录 -->
                    <TextBlock Text="输出目录"
                               FontSize="13"
                               Foreground="#5C635D"
                               Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="TxtOutputDir"
                                 Grid.Column="0"
                                 Height="44"
                                 FontSize="14"
                                 IsReadOnly="True"
                                 Background="#F7F4EF"
                                 BorderBrush="#E7E1D7"
                                 BorderThickness="1.5"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,12,0"
                                 Tag="请选择生成的 Word 文档输出保存目录..."/>

                        <Button Grid.Column="1"
                                x:Name="BtnBrowseOutputDir"
                                Content="选择目录"
                                Width="110"
                                Height="44"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Background="#2196F3"
                                Foreground="White"
                                BorderThickness="0"
                                Click="BtnBrowseOutputDir_Click"
                                Cursor="Hand"/>
                    </Grid>

                    <!-- 文件名模板 -->
                    <TextBlock Text="文件名模板"
                               FontSize="13"
                               Foreground="#5C635D"
                               Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="TxtFileNameTemplate"
                                 Grid.Column="0"
                                 Height="44"
                                 FontSize="14"
                                 IsReadOnly="True"
                                 Background="#F7F4EF"
                                 BorderBrush="#E7E1D7"
                                 BorderThickness="1.5"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,8,0"
                                 Text="文档-{{序号}}.docx"/>

                        <ComboBox x:Name="CmbInsertVariable"
                                  Grid.Column="1"
                                  Height="44"
                                  FontSize="13"
                                  Padding="10,0"
                                  Background="White"
                                  BorderBrush="#E7E1D7"
                                  BorderThickness="1.5"
                                  VerticalContentAlignment="Center"
                                  Margin="0,0,8,0"
                                  SelectionChanged="CmbInsertVariable_SelectionChanged"/>

                        <Button Grid.Column="2"
                                x:Name="BtnFileNameHelp"
                                Content="清空"
                                ToolTip="重置文件名模板为默认序号"
                                Width="110"
                                Height="44"
                                FontSize="13"
                                Background="#F7F4EF"
                                Foreground="#C4612F"
                                BorderThickness="0"
                                Click="BtnFileNameHelp_Click"
                                Cursor="Hand"/>
                    </Grid>
                    <TextBlock FontSize="11"
                               Foreground="#9CA39E"
                               Margin="0,4,0,0"
                               Text="文件名由选择的变量拼接而成，只允许从下拉框中选择变量，可点击清空重置"/>

                    <!-- 子目录设置 -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <CheckBox x:Name="ChkSubfolder"
                                  Content="以变量"
                                  FontWeight="Bold"
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  VerticalContentAlignment="Center"
                                  Checked="ChkSubfolder_Changed"
                                  Unchecked="ChkSubfolder_Changed"/>
                        <ComboBox x:Name="CmbSubfolderVar"
                                  Width="120"
                                  Height="28"
                                  Margin="8,0,8,0"
                                  VerticalContentAlignment="Center"
                                  SelectionChanged="CmbSubfolderVar_SelectionChanged"/>
                        <TextBlock Text="的值创建子目录"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== 进度条 ===== -->
            <Border x:Name="PanelProgress"
                    Background="White"
                    BorderBrush="#E7E1D7"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="24"
                    Margin="0,0,0,16"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="正在生成文档..."
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#1F2421"
                               Margin="0,0,0,12"/>
                    <ProgressBar x:Name="ProgressBar"
                                 Height="10"
                                 Foreground="#C4612F"
                                 Background="#EBE7DE"
                                 BorderThickness="0"
                                 Margin="0,0,0,8"/>
                    <TextBlock x:Name="TxtProgress"
                               Text="准备中..."
                               FontSize="13"
                               Foreground="#5C635D"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ===== 生成结果 ===== -->
            <Border x:Name="PanelResults"
                    Background="White"
                    BorderBrush="#E7E1D7"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="24"
                    Margin="0,0,0,16"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="TxtResultHeader"
                               Text="生成完成"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#1F2421"
                               Margin="0,0,0,12"/>
                    <ItemsControl x:Name="ResultItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F7F4EF"
                                        BorderBrush="#EBE7DE"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="14"
                                        Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#1F2421">
                                            <Run Text="📄 "/>
                                            <Run Text="{Binding Mode=OneWay}"/>
                                        </TextBlock>
                                        <Button Grid.Column="1"
                                                Content="查看文档"
                                                Width="80"
                                                Height="28"
                                                Margin="0,0,8,0"
                                                Style="{StaticResource SecondaryButton}"
                                                Padding="0"
                                                Click="BtnOpenResult_Click"
                                                Tag="{Binding Mode=OneWay}"/>
                                        <Button Grid.Column="2"
                                                Content="定位"
                                                Width="60"
                                                Height="28"
                                                Style="{StaticResource SecondaryButton}"
                                                Padding="0"
                                                Click="BtnLocateResult_Click"
                                                Tag="{Binding Mode=OneWay}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ===== 生成按钮 ===== -->
            <Button x:Name="BtnGenerate"
                    Content="🚀 开始批量生成"
                    Width="250"
                    Height="56"
                    FontSize="18"
                    FontWeight="Bold"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0"
                    HorizontalAlignment="Center"
                    Click="BtnGenerate_Click"
                    Cursor="Hand"
                    Margin="0,10,0,0"/>

        </StackPanel>
    </ScrollViewer>
</Page>
