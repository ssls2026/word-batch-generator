<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ========================================
         Primary Brand Colors
         ======================================== -->

    <!-- 主色：陶土橙 -->
    <Color x:Key="PrimaryColor">#C4612F</Color>
    <Color x:Key="PrimaryDarkColor">#A94E22</Color>
    <Color x:Key="PrimaryLightColor">#D87B4D</Color>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>

    <!-- 主色软调：用于标签和图标芯片 -->
    <Color x:Key="PrimaryTintColor">#F2E3D6</Color>
    <SolidColorBrush x:Key="PrimaryTintBrush" Color="{StaticResource PrimaryTintColor}"/>

    <!-- ========================================
         Background & Surface Colors
         ======================================== -->

    <!-- 背景：暖色奶油白 -->
    <Color x:Key="BackgroundColor">#F7F4EF</Color>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>

    <!-- 表面：浅米色 -->
    <Color x:Key="SurfaceColor">#FBF9F5</Color>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>

    <!-- 纯白表面 -->
    <Color x:Key="SurfaceWhiteColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="SurfaceWhiteBrush" Color="{StaticResource SurfaceWhiteColor}"/>

    <!-- 深色背景：暖炭灰 -->
    <Color x:Key="SurfaceDarkColor">#1F2421</Color>
    <SolidColorBrush x:Key="SurfaceDarkBrush" Color="{StaticResource SurfaceDarkColor}"/>

    <!-- ========================================
         Text Colors
         ======================================== -->

    <!-- 主文本：墨色 -->
    <Color x:Key="TextPrimaryColor">#1F2421</Color>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>

    <!-- 次要文本：静音灰绿 -->
    <Color x:Key="TextSecondaryColor">#5C635D</Color>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>

    <!-- 禁用文本 -->
    <Color x:Key="TextDisabledColor">#9CA39E</Color>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}"/>

    <!-- 反色文本（用于深色背景） -->
    <Color x:Key="TextOnDarkColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="TextOnDarkBrush" Color="{StaticResource TextOnDarkColor}"/>

    <!-- 主色上的文本 -->
    <Color x:Key="TextOnPrimaryColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="{StaticResource TextOnPrimaryColor}"/>

    <!-- ========================================
         Border Colors
         ======================================== -->

    <!-- 细线边框：暖色发际线 -->
    <Color x:Key="BorderColor">#E7E1D7</Color>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

    <!-- 强调边框 -->
    <Color x:Key="BorderEmphasisColor">#D4CEC2</Color>
    <SolidColorBrush x:Key="BorderEmphasisBrush" Color="{StaticResource BorderEmphasisColor}"/>

    <!-- 分隔线 -->
    <Color x:Key="DividerColor">#EBE7DE</Color>
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}"/>

    <!-- ========================================
         Functional Colors
         ======================================== -->

    <!-- 成功 -->
    <Color x:Key="SuccessColor">#4CAF50</Color>
    <Color x:Key="SuccessLightColor">#81C784</Color>
    <Color x:Key="SuccessDarkColor">#388E3C</Color>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="SuccessLightBrush" Color="{StaticResource SuccessLightColor}"/>
    <SolidColorBrush x:Key="SuccessDarkBrush" Color="{StaticResource SuccessDarkColor}"/>

    <!-- 警告 -->
    <Color x:Key="WarningColor">#FF9800</Color>
    <Color x:Key="WarningLightColor">#FFB74D</Color>
    <Color x:Key="WarningDarkColor">#F57C00</Color>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="WarningLightBrush" Color="{StaticResource WarningLightColor}"/>
    <SolidColorBrush x:Key="WarningDarkBrush" Color="{StaticResource WarningDarkColor}"/>

    <!-- 错误 -->
    <Color x:Key="ErrorColor">#F44336</Color>
    <Color x:Key="ErrorLightColor">#E57373</Color>
    <Color x:Key="ErrorDarkColor">#D32F2F</Color>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="ErrorLightBrush" Color="{StaticResource ErrorLightColor}"/>
    <SolidColorBrush x:Key="ErrorDarkBrush" Color="{StaticResource ErrorDarkColor}"/>

    <!-- 信息 -->
    <Color x:Key="InfoColor">#2196F3</Color>
    <Color x:Key="InfoLightColor">#64B5F6</Color>
    <Color x:Key="InfoDarkColor">#1976D2</Color>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    <SolidColorBrush x:Key="InfoLightBrush" Color="{StaticResource InfoLightColor}"/>
    <SolidColorBrush x:Key="InfoDarkBrush" Color="{StaticResource InfoDarkColor}"/>

    <!-- ========================================
         Shadow Colors (for DropShadowEffect)
         ======================================== -->

    <!-- Elevation 1: 卡片默认阴影 -->
    <Color x:Key="ShadowColor1">#14000000</Color>

    <!-- Elevation 2: 卡片悬停阴影 -->
    <Color x:Key="ShadowColor2">#1F000000</Color>

    <!-- Elevation 3: 对话框阴影 -->
    <Color x:Key="ShadowColor3">#29000000</Color>

    <!-- Elevation 4: 弹出菜单阴影 -->
    <Color x:Key="ShadowColor4">#33000000</Color>

    <!-- ========================================
         Overlay Colors
         ======================================== -->

    <!-- 遮罩层 -->
    <Color x:Key="OverlayColor">#80000000</Color>
    <SolidColorBrush x:Key="OverlayBrush" Color="{StaticResource OverlayColor}"/>

    <!-- 悬停覆盖 -->
    <Color x:Key="HoverOverlayColor">#0A000000</Color>
    <SolidColorBrush x:Key="HoverOverlayBrush" Color="{StaticResource HoverOverlayColor}"/>

    <!-- 按下覆盖 -->
    <Color x:Key="PressedOverlayColor">#14000000</Color>
    <SolidColorBrush x:Key="PressedOverlayBrush" Color="{StaticResource PressedOverlayColor}"/>

</ResourceDictionary>
