<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 引入颜色和排版资源 -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Colors.xaml"/>
        <ResourceDictionary Source="Typography.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ========================================
         Card Base Style
         ======================================== -->

    <Style x:Key="CardBase" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceWhiteBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform/>
            </Setter.Value>
        </Setter>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect ShadowDepth="2"
                                Direction="270"
                                BlurRadius="8"
                                Opacity="0.08"
                                Color="#000000"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========================================
         Interactive Card - 带悬停效果
         ======================================== -->

    <Style x:Key="InteractiveCard" TargetType="Border" BasedOn="{StaticResource CardBase}">
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <!-- Y轴上浮2px -->
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                           To="-2"
                                           Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <!-- 阴影加深 -->
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.ShadowDepth)"
                                           To="4"
                                           Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                           To="16"
                                           Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                           To="0.12"
                                           Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                           To="0"
                                           Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.ShadowDepth)"
                                           To="2"
                                           Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                           To="8"
                                           Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                           To="0.08"
                                           Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ========================================
         Elevated Card - 更高的阴影层级
         ======================================== -->

    <Style x:Key="ElevatedCard" TargetType="Border" BasedOn="{StaticResource CardBase}">
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect ShadowDepth="4"
                                Direction="270"
                                BlurRadius="16"
                                Opacity="0.12"
                                Color="#000000"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========================================
         Outlined Card - 无阴影，突出边框
         ======================================== -->

    <Style x:Key="OutlinedCard" TargetType="Border" BasedOn="{StaticResource CardBase}">
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Effect" Value="{x:Null}"/>
    </Style>

    <!-- ========================================
         Filled Card - 带背景色的卡片
         ======================================== -->

    <Style x:Key="FilledCard" TargetType="Border" BasedOn="{StaticResource CardBase}">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- ========================================
         Primary Card - 主色调卡片
         ======================================== -->

    <Style x:Key="PrimaryCard" TargetType="Border" BasedOn="{StaticResource CardBase}">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryDarkBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <!-- ========================================
         Feature Card - 特性展示卡片（带图标）
         ======================================== -->

    <Style x:Key="FeatureCard" TargetType="Border" BasedOn="{StaticResource InteractiveCard}">
        <Setter Property="Padding" Value="24"/>
        <Setter Property="MinHeight" Value="160"/>
    </Style>

    <!-- ========================================
         Compact Card - 紧凑型卡片
         ======================================== -->

    <Style x:Key="CompactCard" TargetType="Border" BasedOn="{StaticResource CardBase}">
        <Setter Property="Padding" Value="12"/>
        <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <!-- ========================================
         Large Card - 大型卡片
         ======================================== -->

    <Style x:Key="LargeCard" TargetType="Border" BasedOn="{StaticResource CardBase}">
        <Setter Property="Padding" Value="32"/>
        <Setter Property="CornerRadius" Value="12"/>
    </Style>

    <!-- ========================================
         Status Cards - 功能状态卡片
         ======================================== -->

    <Style x:Key="SuccessCard" TargetType="Border" BasedOn="{StaticResource CardBase}">
        <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource SuccessColor}" Opacity="0.05"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="WarningCard" TargetType="Border" BasedOn="{StaticResource CardBase}">
        <Setter Property="BorderBrush" Value="{StaticResource WarningBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource WarningColor}" Opacity="0.05"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ErrorCard" TargetType="Border" BasedOn="{StaticResource CardBase}">
        <Setter Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource ErrorColor}" Opacity="0.05"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="InfoCard" TargetType="Border" BasedOn="{StaticResource CardBase}">
        <Setter Property="BorderBrush" Value="{StaticResource InfoBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource InfoColor}" Opacity="0.05"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========================================
         Chip/Tag Style - 小标签芯片
         ======================================== -->

    <Style x:Key="Chip" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PrimaryTintBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="999"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="ChipText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightMedium}"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
    </Style>

    <!-- ========================================
         Badge Style - 徽章
         ======================================== -->

    <Style x:Key="Badge" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ErrorBrush}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="MinWidth" Value="20"/>
        <Setter Property="MinHeight" Value="20"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="BadgeText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightBold}"/>
        <Setter Property="Foreground" Value="{StaticResource TextOnDarkBrush}"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <!-- ========================================
         Divider Style - 分隔线
         ======================================== -->

    <Style x:Key="Divider" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource DividerBrush}"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="0,16"/>
    </Style>

    <Style x:Key="VerticalDivider" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource DividerBrush}"/>
        <Setter Property="Width" Value="1"/>
        <Setter Property="Margin" Value="16,0"/>
    </Style>

    <!-- ========================================
         Panel/Container Styles
         ======================================== -->

    <Style x:Key="Panel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="20"/>
    </Style>

    <Style x:Key="Section" TargetType="Border">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="0,24"/>
    </Style>

</ResourceDictionary>
