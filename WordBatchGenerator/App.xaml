                            <Grid x:Name="ButtonGrid">
                                <!-- Base Background with Shadow -->
                                <Border x:Name="BaseBorder"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="10">
                                    <Border.Effect>
                                        <DropShadowEffect x:Name="ButtonShadow"
