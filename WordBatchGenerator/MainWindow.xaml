<Window x:Class="WordBatchGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Word 批量生成器 v2.0"
        Height="760" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <!-- 导航按钮项模板 -->
        <Style x:Key="NavItemStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="8,2,8,2"/>
            <Setter Property="Padding" Value="16,0,16,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Name="NavBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="14,0"
                                Height="44">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 选中指示条 -->
                                <Border Name="SelectionIndicator"
                                        Grid.Column="0"
                                        Width="4"
                                        Background="Transparent"
                                        CornerRadius="2"
                                        VerticalAlignment="Stretch"
                                        Margin="-14,6,-10,6"/>

                                <!-- 图标 -->
                                <TextBlock Name="NavIcon"
                                           Grid.Column="1"
                                           FontSize="18"
                                           Margin="0,0,12,0"
                                           VerticalAlignment="Center"/>

                                <!-- 文本 -->
                                <ContentPresenter Grid.Column="2"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#1E2A28"/>
                                <Setter TargetName="SelectionIndicator" Property="Background" Value="#C4612F"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#2A3634"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 主窗口边框 + 阴影 -->
    <Border Background="{StaticResource SurfaceWhiteBrush}"
            CornerRadius="14"
            Margin="6">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30"
                              ShadowDepth="2"
                              Opacity="0.15"
                              Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ========== 自定义标题栏 ========== -->
            <Grid Grid.Row="0"
                  Background="{StaticResource SurfaceWhiteBrush}"
                  MouseLeftButtonDown="Window_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="📄  Word 批量生成器"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="18,0,0,0"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,8,0">
                    <Button Content="─"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="BtnMinimize_Click"/>
                    <Button Content="□"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="BtnMaximize_Click"/>
                    <Button Content="✕"
                            Style="{StaticResource TitleBarCloseButtonStyle}"
                            Click="BtnClose_Click"/>
                </StackPanel>
            </Grid>

            <!-- ========== 主体内容 ========== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧导航栏 -->
                <Border Grid.Column="0"
                        Background="#1B1F1D"
                        CornerRadius="0,0,0,14"
                        Padding="12,16,12,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Logo -->
                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    Margin="12,6,0,24">
                            <Border Background="#C4612F"
                                    Width="36" Height="36"
                                    CornerRadius="10">
                                <TextBlock Text="W"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Word"
                                           FontSize="17"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           LineHeight="20"/>
                                <TextBlock Text="批量生成器"
                                           FontSize="13"
                                           Foreground="#9CA3AF"
                                           LineHeight="18"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- 导航菜单 -->
                        <StackPanel Grid.Row="1">
                            <RadioButton x:Name="BtnNewScheme"
                                         Style="{StaticResource NavItemStyle}"
                                         IsChecked="True"
                                         Checked="NavButton_Checked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="＋" FontSize="16" Foreground="#34D399" Width="24"/>
                                    <TextBlock Text="创建新方案" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                </StackPanel>
                            </RadioButton>

                            <RadioButton x:Name="BtnSchemeList"
                                         Style="{StaticResource NavItemStyle}"
                                         Checked="NavButton_Checked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="☰" FontSize="16" Foreground="#60A5FA" Width="24"/>
                                    <TextBlock Text="方案管理" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                </StackPanel>
                            </RadioButton>

                            <RadioButton x:Name="BtnGenerate"
                                         Style="{StaticResource NavItemStyle}"
                                         Checked="NavButton_Checked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚡" FontSize="16" Foreground="#FBBF24" Width="24"/>
                                    <TextBlock Text="批量生成" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>

                        <!-- 底部版本信息 -->
                        <TextBlock Grid.Row="3"
                                   Text="v2.0 · C# .NET 8"
                                   FontSize="11"
                                   Foreground="#4B5563"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                    </Grid>
                </Border>

                <!-- 右侧内容区 -->
                <Border Grid.Column="1"
                        Background="#F7F4EF"
                        CornerRadius="0,0,14,0">
                    <Frame x:Name="ContentFrame"
                           NavigationUIVisibility="Hidden"
                           Background="Transparent"
                           JournalOwnership="OwnsJournal"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
